# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://username:password@localhost:5432/portfolio_saas"

# For Vercel Postgres or Supabase, use:
# DATABASE_URL="postgresql://username:password@host:5432/dbname?sslmode=require"

# ============================================================
# NEXT AUTH
# ============================================================
NEXTAUTH_SECRET="your-super-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# For production:
# NEXTAUTH_URL="https://yourdomain.com"

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_NAME="Portfolio & Business Suite"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DESCRIPTION="Modern Portfolio & Business Management Platform"

# ============================================================
# OPTIONAL: EMAIL (for contact form)
# ============================================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@yourdomain.com"

